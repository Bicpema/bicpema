{
  "name": "simulations",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup": "copyfiles -f node_modules/p5/lib/p5.min.js node_modules/bootstrap/dist/css/bootstrap.min.css node_modules/bootstrap/dist/css/bootstrap.min.css.map node_modules/bootstrap/dist/js/bootstrap.bundle.min.js node_modules/bootstrap/dist/js/bootstrap.bundle.min.js.map vite/lib/"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "copyfiles": "^2.4.1",
    "prettier": "3.6.2",
    "sass": "^1.92.1",
    "vite": "^7.1.5",
    "vite-plugin-static-copy": "^3.1.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.0",
    "html2canvas": "^1.4.1",
    "jquery": "^3.7.1",
    "mathjs": "^14.7.0",
    "matter-js": "^0.20.0",
    "p5": "^1.11.10"
  }
}
